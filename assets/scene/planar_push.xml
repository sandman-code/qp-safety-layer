<mujoco model="planar_push">
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="2d" name="checker" builtin="checker"
             rgb1="0.25 0.30 0.35" rgb2="0.18 0.22 0.28" width="512" height="512"/>
    <material name="table_mat" texture="checker" texrepeat="6 6"
              specular="0.3" shininess="0.2"/>
    <material name="ee_mat"   rgba="0.20 0.40 0.85 1.0" specular="0.9" shininess="0.8"/>
    <material name="obj_mat"  rgba="0.90 0.50 0.10 1.0" specular="0.5" shininess="0.3"/>
    <material name="goal_mat" rgba="0.10 0.85 0.10 0.45"/>
  </asset>

  <worldbody>
    <!-- Static table surface -->
    <geom name="tabletop" type="box" size="0.45 0.45 0.01" pos="0 0 0.41"
          material="table_mat" condim="3" friction="0.5 0.005 0.0001"/>

    <!-- End-effector puck — mocap-controlled kinematic body -->
    <body name="ee" mocap="true" pos="0 0 0.435">
      <geom name="ee_geom" type="cylinder" size="0.025 0.015"
            material="ee_mat" condim="4" friction="0.5 0.005 0.0001"/>
    </body>

    <!-- Pushable box — free body driven by contact -->
    <body name="object" pos="0.05 0.05 0.435">
      <freejoint name="object_joint"/>
      <geom name="obj_geom" type="box" size="0.025 0.025 0.015"
            material="obj_mat" mass="0.1" condim="4" friction="0.5 0.005 0.0001"/>
      <site name="obj_center" size="0.003" rgba="1 1 1 0.8"/>
    </body>

    <!-- Goal marker (visual only, repositioned at reset) -->
    <site name="goal" pos="0.15 0.10 0.422" type="cylinder"
          size="0.03 0.001" material="goal_mat"/>

    <!-- Cameras -->
    <camera name="overhead" pos="0 0 1.2" quat="1 0 0 0" mode="fixed"/>
    <camera name="side"     pos="0.9 0 0.75" xyaxes="-1 0 0 0 -0.5 0.866" mode="fixed"/>
  </worldbody>

  <contact>
    <pair geom1="ee_geom"  geom2="obj_geom"  condim="4"/>
    <pair geom1="obj_geom" geom2="tabletop"  condim="4"/>
  </contact>
</mujoco>
